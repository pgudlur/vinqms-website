---
---

<footer class="bg-[#0F172A] text-slate-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Column 1: Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2">
          <svg
            class="h-8 w-8"
            viewBox="0 0 32 32"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect width="32" height="32" rx="8" fill="#0D9488" />
            <path
              d="M8 10L16 24L24 10"
              stroke="white"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <span class="text-xl font-bold">
            <span class="text-white">vin</span><span class="text-[#0D9488]"
              >Reliability</span
            >
          </span>
        </a>
        <p class="mt-3 text-sm text-slate-400 max-w-xs">
          Quality &amp; Reliability Engineering Platform
        </p>
        <a
          href="mailto:support@vinreliability.net"
          class="mt-3 inline-block text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
        >
          support@vinreliability.net
        </a>
      </div>

      <!-- Column 2: Products -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">
          Products
        </h3>
        <ul class="mt-4 space-y-2.5">
          <li>
            <a
              href="/quality"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              vinQuality
            </a>
          </li>
          <li>
            <a
              href="/fmea"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              vinFMEA
            </a>
          </li>
          <li>
            <a
              href="/reliability"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              vinReliability
            </a>
          </li>
          <li>
            <a
              href="/pricing"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              Pricing
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Resources -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">
          Resources
        </h3>
        <ul class="mt-4 space-y-2.5">
          <li>
            <span class="text-sm text-slate-500">Documentation</span>
          </li>
          <li>
            <span class="text-sm text-slate-500">API Reference</span>
          </li>
          <li>
            <span class="text-sm text-slate-500">System Status</span>
          </li>
          <li>
            <span class="text-sm text-slate-500">Release Notes</span>
          </li>
        </ul>
      </div>

      <!-- Column 4: Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">
          Company
        </h3>
        <ul class="mt-4 space-y-2.5">
          <li>
            <a
              href="/about"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              About
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              Contact
            </a>
          </li>
          <li>
            <a
              href="/privacy"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              Privacy
            </a>
          </li>
          <li>
            <a
              href="/terms"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              Terms
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 border-t border-slate-800 pt-8">
      <p class="text-center text-sm text-slate-500">
        &copy; 2026 vinReliability LLC. All rights reserved.
      </p>
      <p class="mt-1 text-center text-xs text-slate-600">
        vinQuality, vinFMEA, and vinReliability are trademarks of vinReliability
        LLC.
      </p>
    </div>
  </div>
</footer>
