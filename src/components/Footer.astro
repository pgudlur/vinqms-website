---
---

<footer class="bg-[#0F172A] text-slate-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Column 1: Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-1.5">
          <svg viewBox="0 0 200 40" class="h-9 w-auto" xmlns="http://www.w3.org/2000/svg">
            <g transform="translate(0,8)">
              <path d="M 0.96,1.44 C 0.48,7.2 4.32,14.88 10.68,19.68 C 10.68,19.44 11.52,22.32 12,22.32 C 12.48,22.32 13.32,19.44 13.32,19.68 C 19.68,14.88 23.52,7.2 23.04,1.44 L 18.24,1.44 C 17.28,5.28 14.88,11.52 13.2,17.28 C 12.48,18.24 11.52,18.24 10.8,17.28 C 9.12,11.52 6.72,5.28 5.76,1.44 Z" fill="#FFFFFF"/>
              <path d="M 12,2.4 C 12.96,6 14.64,10.08 14.64,13.92 C 14.64,15.36 13.32,16.8 12,16.8 C 10.68,16.8 9.36,15.36 9.36,13.92 C 9.36,10.08 11.04,6 12,2.4 Z" fill="#EF4444"/>
            </g>
            <text x="30" y="28" font-family="'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif" font-size="18" font-weight="700" fill="#FFFFFF">Vin</text>
            <text x="62" y="28" font-family="'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif" font-size="18" font-weight="600" fill="#0D9488">Reliability</text>
            <text x="160" y="18" font-family="'Segoe UI', sans-serif" font-size="7" fill="#64748B">™</text>
          </svg>
        </a>
        <p class="mt-3 text-sm text-slate-400 max-w-xs">
          Quality &amp; Reliability Engineering Platform
        </p>
        <a
          href="mailto:support@vinreliability.net"
          class="mt-3 inline-block text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
        >
          support@vinreliability.net
        </a>
      </div>

      <!-- Column 2: Products -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">
          Products
        </h3>
        <ul class="mt-4 space-y-2.5">
          <li>
            <a
              href="/quality"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              vinQuality
            </a>
          </li>
          <li>
            <a
              href="/fmea"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              vinFMEA
            </a>
          </li>
          <li>
            <a
              href="/reliability"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              vinReliability
            </a>
          </li>
          <li>
            <a
              href="/pricing"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              Pricing
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Learn -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">
          Learn
        </h3>
        <ul class="mt-4 space-y-2.5">
          <li>
            <a href="/about" class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors">About Us</a>
          </li>
          <li>
            <a href="/pricing" class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors">Compare Plans</a>
          </li>
          <li>
            <a href="/contact" class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors">Request Demo</a>
          </li>
          <li>
            <a href="mailto:support@vinreliability.net" class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors">Support</a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">
          Company
        </h3>
        <ul class="mt-4 space-y-2.5">
          <li>
            <a
              href="/about"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              About
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              Contact
            </a>
          </li>
          <li>
            <a
              href="/privacy"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              Privacy
            </a>
          </li>
          <li>
            <a
              href="/terms"
              class="text-sm text-slate-400 hover:text-[#14B8A6] transition-colors"
            >
              Terms
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 border-t border-slate-800 pt-8">
      <p class="text-center text-sm text-slate-500">
        &copy; 2026 vinReliability LLC. All rights reserved.
      </p>
      <p class="mt-1 text-center text-xs text-slate-600">
        vinQuality, vinFMEA, and vinReliability are trademarks of vinReliability
        LLC.
      </p>
    </div>
  </div>
</footer>
