---
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200/60"
>
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <svg
          class="h-8 w-8"
          viewBox="0 0 32 32"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <rect width="32" height="32" rx="8" fill="#0D9488" />
          <path
            d="M8 10L16 24L24 10"
            stroke="white"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <span class="text-xl font-bold">
          <span class="text-slate-900">vin</span><span class="text-[#0D9488]"
            >Reliability</span
          >
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        <!-- Products Dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-slate-700 hover:text-[#0D9488] rounded-lg transition-colors"
          >
            Products
            <svg
              class="h-4 w-4 transition-transform group-hover:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <!-- Dropdown Panel -->
          <div
            class="invisible opacity-0 group-hover:visible group-hover:opacity-100 absolute top-full left-0 pt-2 transition-all duration-200"
          >
            <div
              class="w-80 rounded-xl bg-white shadow-xl ring-1 ring-slate-200/60 p-2"
            >
              <a
                href="/quality"
                class="flex items-start gap-3 rounded-lg p-3 hover:bg-slate-50 transition-colors"
              >
                <div
                  class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#0D9488]/10"
                >
                  <svg
                    class="h-5 w-5 text-[#0D9488]"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900">
                    vinQuality
                  </div>
                  <div class="text-xs text-slate-500">
                    Quality Management System for NCMRs, CAPAs, and compliance
                  </div>
                </div>
              </a>
              <a
                href="/fmea"
                class="flex items-start gap-3 rounded-lg p-3 hover:bg-slate-50 transition-colors"
              >
                <div
                  class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-amber-500/10"
                >
                  <svg
                    class="h-5 w-5 text-amber-500"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900">
                    vinFMEA
                  </div>
                  <div class="text-xs text-slate-500">
                    Failure Mode & Effects Analysis with risk matrices
                  </div>
                </div>
              </a>
              <a
                href="/reliability"
                class="flex items-start gap-3 rounded-lg p-3 hover:bg-slate-50 transition-colors"
              >
                <div
                  class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue-500/10"
                >
                  <svg
                    class="h-5 w-5 text-blue-500"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900">
                    vinReliability
                  </div>
                  <div class="text-xs text-slate-500">
                    Statistical analysis, Weibull modeling, and reliability
                    engineering
                  </div>
                </div>
              </a>
            </div>
          </div>
        </div>

        <a
          href="/pricing"
          class="px-3 py-2 text-sm font-medium text-slate-700 hover:text-[#0D9488] rounded-lg transition-colors"
        >
          Pricing
        </a>
        <a
          href="/about"
          class="px-3 py-2 text-sm font-medium text-slate-700 hover:text-[#0D9488] rounded-lg transition-colors"
        >
          About
        </a>
        <a
          href="/contact"
          class="px-3 py-2 text-sm font-medium text-slate-700 hover:text-[#0D9488] rounded-lg transition-colors"
        >
          Contact
        </a>
      </div>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-lg bg-[#0D9488] px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[#0F766E] transition-colors"
        >
          Get Started
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-lg p-2 text-slate-700 hover:bg-slate-100 transition-colors"
        aria-label="Toggle navigation menu"
      >
        <svg
          id="hamburger-icon"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="hidden h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200/60">
      <div class="space-y-1 px-2 pb-4 pt-2">
        <div class="px-3 py-2 text-xs font-semibold uppercase tracking-wider text-slate-400">
          Products
        </div>
        <a
          href="/quality"
          class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-[#0D9488]"
        >
          vinQuality — QMS Platform
        </a>
        <a
          href="/fmea"
          class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-[#0D9488]"
        >
          vinFMEA — FMEA Suite
        </a>
        <a
          href="/reliability"
          class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-[#0D9488]"
        >
          vinReliability — Statistical Analysis
        </a>

        <div class="my-2 border-t border-slate-200/60"></div>

        <a
          href="/pricing"
          class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-[#0D9488]"
        >
          Pricing
        </a>
        <a
          href="/about"
          class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-[#0D9488]"
        >
          About
        </a>
        <a
          href="/contact"
          class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-[#0D9488]"
        >
          Contact
        </a>

        <div class="pt-2 px-3">
          <a
            href="/contact"
            class="block w-full rounded-lg bg-[#0D9488] px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-[#0F766E] transition-colors"
          >
            Get Started
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<!-- Spacer to offset fixed header -->
<div class="h-16"></div>

<script>
  const btn = document.querySelector('#mobile-menu-btn');
  const menu = document.querySelector('#mobile-menu');
  const hamburger = document.querySelector('#hamburger-icon');
  const closeIcon = document.querySelector('#close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
