---
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200/60"
>
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-1.5 shrink-0">
        <svg viewBox="0 0 200 40" class="h-9 w-auto" xmlns="http://www.w3.org/2000/svg">
          <g transform="translate(0,8)">
            <path d="M 0.96,1.44 C 0.48,7.2 4.32,14.88 10.68,19.68 C 10.68,19.44 11.52,22.32 12,22.32 C 12.48,22.32 13.32,19.44 13.32,19.68 C 19.68,14.88 23.52,7.2 23.04,1.44 L 18.24,1.44 C 17.28,5.28 14.88,11.52 13.2,17.28 C 12.48,18.24 11.52,18.24 10.8,17.28 C 9.12,11.52 6.72,5.28 5.76,1.44 Z" fill="#0F172A"/>
            <path d="M 12,2.4 C 12.96,6 14.64,10.08 14.64,13.92 C 14.64,15.36 13.32,16.8 12,16.8 C 10.68,16.8 9.36,15.36 9.36,13.92 C 9.36,10.08 11.04,6 12,2.4 Z" fill="#EF4444"/>
          </g>
          <text x="30" y="28" font-family="'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif" font-size="18" font-weight="700" fill="#0F172A">Vin</text>
          <text x="62" y="28" font-family="'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif" font-size="18" font-weight="600" fill="#0D9488">Reliability</text>
          <text x="160" y="18" font-family="'Segoe UI', sans-serif" font-size="7" fill="#94A3B8">™</text>
        </svg>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        <!-- Products Dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-slate-700 hover:text-[#0D9488] rounded-lg transition-colors"
          >
            Products
            <svg
              class="h-4 w-4 transition-transform group-hover:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <!-- Dropdown Panel -->
          <div
            class="invisible opacity-0 group-hover:visible group-hover:opacity-100 absolute top-full left-0 pt-2 transition-all duration-200"
          >
            <div
              class="w-80 rounded-xl bg-white shadow-xl ring-1 ring-slate-200/60 p-2"
            >
              <div class="rounded-lg p-3 hover:bg-slate-50 transition-colors">
                <a href="/quality" class="flex items-start gap-3">
                  <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#0D9488]/10">
                    <svg class="h-5 w-5 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-slate-900">vinQuality</div>
                    <div class="text-xs text-slate-500">Quality Management System for NCMRs, CAPAs, and compliance</div>
                  </div>
                </a>
                <div class="mt-2 ml-12 flex items-center gap-3">
                  <a href="https://frontend-production-bec1.up.railway.app/login" class="text-[11px] font-medium text-[#0D9488] hover:text-[#0F766E] transition-colors">Sign In</a>
                  <span class="text-slate-300">|</span>
                  <a href="https://frontend-production-bec1.up.railway.app/register" class="text-[11px] font-medium text-[#0D9488] hover:text-[#0F766E] transition-colors">Free Trial</a>
                </div>
              </div>
              <div class="rounded-lg p-3 hover:bg-slate-50 transition-colors">
                <a href="/fmea" class="flex items-start gap-3">
                  <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-amber-500/10">
                    <svg class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-slate-900">vinFMEA</div>
                    <div class="text-xs text-slate-500">Failure Mode & Effects Analysis with risk matrices</div>
                  </div>
                </a>
                <div class="mt-2 ml-12 flex items-center gap-3">
                  <a href="https://vinfmea.com/login" class="text-[11px] font-medium text-amber-600 hover:text-amber-700 transition-colors">Sign In</a>
                  <span class="text-slate-300">|</span>
                  <a href="https://vinfmea.com/login" class="text-[11px] font-medium text-amber-600 hover:text-amber-700 transition-colors">Free Trial</a>
                </div>
              </div>
              <div class="rounded-lg p-3 hover:bg-slate-50 transition-colors">
                <a href="/reliability" class="flex items-start gap-3">
                  <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue-500/10">
                    <svg class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-slate-900">vinReliability</div>
                    <div class="text-xs text-slate-500">Statistical analysis, Weibull modeling, and reliability engineering</div>
                  </div>
                </a>
                <div class="mt-2 ml-12 flex items-center gap-3">
                  <a href="https://app.vinreliability.net/login" class="text-[11px] font-medium text-blue-600 hover:text-blue-700 transition-colors">Sign In</a>
                  <span class="text-slate-300">|</span>
                  <a href="https://app.vinreliability.net/login" class="text-[11px] font-medium text-blue-600 hover:text-blue-700 transition-colors">Free Trial</a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <a
          href="/pricing"
          class="px-3 py-2 text-sm font-medium text-slate-700 hover:text-[#0D9488] rounded-lg transition-colors"
        >
          Pricing
        </a>
        <a
          href="/about"
          class="px-3 py-2 text-sm font-medium text-slate-700 hover:text-[#0D9488] rounded-lg transition-colors"
        >
          About
        </a>
        <a
          href="/contact"
          class="px-3 py-2 text-sm font-medium text-slate-700 hover:text-[#0D9488] rounded-lg transition-colors"
        >
          Contact
        </a>
      </div>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center gap-4">
        <a
          href="https://frontend-production-bec1.up.railway.app/login"
          class="text-sm font-medium text-slate-700 hover:text-[#0D9488] transition-colors"
        >
          Sign In
        </a>
        <a
          href="https://frontend-production-bec1.up.railway.app/register"
          class="inline-flex items-center justify-center rounded-lg bg-[#0D9488] px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[#0F766E] transition-colors"
        >
          Start Free Trial
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-lg p-2 text-slate-700 hover:bg-slate-100 transition-colors"
        aria-label="Toggle navigation menu"
      >
        <svg
          id="hamburger-icon"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="hidden h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200/60">
      <div class="space-y-1 px-2 pb-4 pt-2">
        <div class="px-3 py-2 text-xs font-semibold uppercase tracking-wider text-slate-400">
          Products
        </div>
        <div class="rounded-lg px-3 py-2">
          <a href="/quality" class="block text-sm font-medium text-slate-700 hover:text-[#0D9488]">vinQuality — QMS Platform</a>
          <div class="mt-1 flex items-center gap-3">
            <a href="https://frontend-production-bec1.up.railway.app/login" class="text-xs font-medium text-[#0D9488]">Sign In</a>
            <span class="text-slate-300">|</span>
            <a href="https://frontend-production-bec1.up.railway.app/register" class="text-xs font-medium text-[#0D9488]">Free Trial</a>
          </div>
        </div>
        <div class="rounded-lg px-3 py-2">
          <a href="/fmea" class="block text-sm font-medium text-slate-700 hover:text-[#0D9488]">vinFMEA — FMEA Suite</a>
          <div class="mt-1 flex items-center gap-3">
            <a href="https://vinfmea.com/login" class="text-xs font-medium text-amber-600">Sign In</a>
            <span class="text-slate-300">|</span>
            <a href="https://vinfmea.com/login" class="text-xs font-medium text-amber-600">Free Trial</a>
          </div>
        </div>
        <div class="rounded-lg px-3 py-2">
          <a href="/reliability" class="block text-sm font-medium text-slate-700 hover:text-[#0D9488]">vinReliability — Statistical Analysis</a>
          <div class="mt-1 flex items-center gap-3">
            <a href="https://app.vinreliability.net/login" class="text-xs font-medium text-blue-600">Sign In</a>
            <span class="text-slate-300">|</span>
            <a href="https://app.vinreliability.net/login" class="text-xs font-medium text-blue-600">Free Trial</a>
          </div>
        </div>

        <div class="my-2 border-t border-slate-200/60"></div>

        <a
          href="/pricing"
          class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-[#0D9488]"
        >
          Pricing
        </a>
        <a
          href="/about"
          class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-[#0D9488]"
        >
          About
        </a>
        <a
          href="/contact"
          class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-[#0D9488]"
        >
          Contact
        </a>

        <div class="pt-2 px-3 space-y-2">
          <a
            href="https://frontend-production-bec1.up.railway.app/login"
            class="block w-full rounded-lg border border-[#0D9488] px-4 py-2.5 text-center text-sm font-semibold text-[#0D9488] hover:bg-[#0D9488] hover:text-white transition-colors"
          >
            Sign In
          </a>
          <a
            href="https://frontend-production-bec1.up.railway.app/register"
            class="block w-full rounded-lg bg-[#0D9488] px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-[#0F766E] transition-colors"
          >
            Start Free Trial
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<!-- Spacer to offset fixed header -->
<div class="h-16"></div>

<script>
  const btn = document.querySelector('#mobile-menu-btn');
  const menu = document.querySelector('#mobile-menu');
  const hamburger = document.querySelector('#hamburger-icon');
  const closeIcon = document.querySelector('#close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
