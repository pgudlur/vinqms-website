---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact — vinReliability"
  description="Get in touch with vinReliability. Request a demo, ask about pricing, or get support."
  keywords="contact vinReliability, request demo, vinQuality support, FMEA software contact"
  canonical="/contact"
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-b from-slate-50 to-white py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal">
          <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
            Get in Touch
          </h1>
          <p class="mt-4 max-w-2xl mx-auto text-lg text-slate-600">
            Request a demo, ask about pricing, or reach out for support. We typically respond within one business day.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Form -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
        <div class="reveal">
          <form
            action="https://formspree.io/f/xpwzgwkk"
            method="POST"
            class="space-y-6"
          >
            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-medium text-slate-700">
                Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-colors"
                placeholder="Your full name"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-slate-700">
                Email <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-colors"
                placeholder="you@company.com"
              />
            </div>

            <!-- Company -->
            <div>
              <label for="company" class="block text-sm font-medium text-slate-700">
                Company
              </label>
              <input
                type="text"
                id="company"
                name="company"
                autocomplete="organization"
                class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-colors"
                placeholder="Your company name (optional)"
              />
            </div>

            <!-- Product Interest -->
            <div>
              <label for="product" class="block text-sm font-medium text-slate-700">
                Product Interest
              </label>
              <select
                id="product"
                name="product"
                class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-colors bg-white"
              >
                <option value="General Inquiry">General Inquiry</option>
                <option value="vinQuality">vinQuality</option>
                <option value="vinFMEA">vinFMEA</option>
                <option value="vinReliability">vinReliability</option>
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-slate-700">
                Message <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-colors resize-y"
                placeholder="Tell us how we can help..."
              ></textarea>
            </div>

            <!-- Submit -->
            <div>
              <button
                type="submit"
                class="w-full rounded-lg bg-[#0D9488] px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[#0F766E] focus:ring-2 focus:ring-[#0D9488]/20 focus:ring-offset-2 focus:outline-none transition-colors"
              >
                Send Message
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- Alternative Contact -->
    <section class="py-12 sm:py-16 bg-slate-50">
      <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal">
          <p class="text-base text-slate-600">
            Prefer email? Reach us directly at
            <a href="mailto:support@vinreliability.net" class="font-semibold text-[#0D9488] hover:text-[#0F766E] transition-colors">
              support@vinreliability.net
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
