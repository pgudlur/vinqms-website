---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact — vinReliability"
  description="Get in touch with vinReliability. Request a demo, ask about pricing, or get support."
  keywords="contact vinReliability, request demo, vinQuality support, FMEA software contact"
  canonical="/contact"
>
  <Header />

  <main>
    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0F172A] to-[#1E293B]">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#0D9488] rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-[#6366F1] rounded-full blur-3xl"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 sm:py-28 text-center">
        <div class="reveal">
          <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white">
            Get in Touch
          </h1>
          <p class="mt-4 max-w-2xl mx-auto text-lg text-slate-300">
            Request a demo, ask about pricing, or reach out for support. We'd love to hear from you.
          </p>
        </div>
      </div>
    </section>

    <!-- ============ FORM + SIDEBAR ============ -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

          <!-- Left: Contact Form (2/3 width on desktop) -->
          <div class="lg:col-span-2 reveal-left">
            <div class="card-hover rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
              <h2 class="text-2xl font-bold text-slate-900 mb-6">Send Us a Message</h2>
              <form
                action="https://formspree.io/f/xpwzgwkk"
                method="POST"
                class="space-y-6"
              >
                <!-- Name & Email row -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                  <div>
                    <label for="name" class="block text-sm font-medium text-slate-700">
                      Name <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      autocomplete="name"
                      class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-all duration-200"
                      placeholder="Your full name"
                    />
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-medium text-slate-700">
                      Email <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      autocomplete="email"
                      class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-all duration-200"
                      placeholder="you@company.com"
                    />
                  </div>
                </div>

                <!-- Company & Product row -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                  <div>
                    <label for="company" class="block text-sm font-medium text-slate-700">
                      Company
                    </label>
                    <input
                      type="text"
                      id="company"
                      name="company"
                      autocomplete="organization"
                      class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-all duration-200"
                      placeholder="Your company name"
                    />
                  </div>
                  <div>
                    <label for="product" class="block text-sm font-medium text-slate-700">
                      Product Interest
                    </label>
                    <select
                      id="product"
                      name="product"
                      class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-all duration-200 bg-white"
                    >
                      <option value="General Inquiry">General Inquiry</option>
                      <option value="vinQuality">vinQuality</option>
                      <option value="vinFMEA">vinFMEA</option>
                      <option value="vinReliability">vinReliability</option>
                    </select>
                  </div>
                </div>

                <!-- Message -->
                <div>
                  <label for="message" class="block text-sm font-medium text-slate-700">
                    Message <span class="text-red-500">*</span>
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="5"
                    class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-[#0D9488] focus:ring-2 focus:ring-[#0D9488]/20 focus:outline-none transition-all duration-200 resize-y"
                    placeholder="Tell us how we can help..."
                  ></textarea>
                </div>

                <!-- Submit -->
                <div>
                  <button
                    type="submit"
                    class="w-full rounded-lg bg-[#0D9488] px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[#0F766E] focus:ring-2 focus:ring-[#0D9488]/20 focus:ring-offset-2 focus:outline-none transition-colors"
                  >
                    Send Message
                  </button>
                </div>
              </form>

              <!-- Social proof -->
              <p class="mt-6 text-center text-sm text-slate-500">
                Join 500+ quality teams who chose vinReliability.
              </p>
            </div>
          </div>

          <!-- Right: Info Sidebar (1/3 width on desktop) -->
          <div class="lg:col-span-1 space-y-6 reveal-right">

            <!-- Response time promise -->
            <div class="rounded-xl border border-teal-200 bg-teal-50 p-5">
              <div class="flex items-start gap-3">
                <svg class="h-6 w-6 shrink-0 text-[#0D9488] mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <p class="text-sm font-semibold text-teal-800">Fast Response</p>
                  <p class="mt-1 text-sm text-teal-700">We typically respond within 1 business day.</p>
                </div>
              </div>
            </div>

            <!-- Demo booking CTA -->
            <div class="card-hover rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
              <div class="flex items-center gap-3 mb-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#0D9488]/10">
                  <svg class="h-5 w-5 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-slate-900">Want a Live Demo?</h3>
              </div>
              <p class="text-sm text-slate-600 mb-4">Schedule a 30-minute walkthrough of our platform.</p>
              <a
                href="mailto:support@vinreliability.net?subject=Demo%20Request"
                class="inline-flex w-full items-center justify-center rounded-lg bg-[#0D9488] px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-[#0F766E] transition-colors"
              >
                Request a Demo
              </a>
            </div>

            <!-- Direct contact -->
            <div class="card-hover rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
              <h3 class="text-sm font-semibold text-slate-900 mb-3">Reach Us Directly</h3>
              <a
                href="mailto:support@vinreliability.net"
                class="flex items-center gap-3 text-sm text-slate-600 hover:text-[#0D9488] transition-colors"
              >
                <svg class="h-5 w-5 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                support@vinreliability.net
              </a>
            </div>

            <!-- Mini FAQ -->
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
              <h3 class="text-sm font-semibold text-slate-900 mb-4">Frequently Asked</h3>
              <div class="space-y-3">
                <!-- FAQ 1 -->
                <div class="rounded-lg border border-slate-100">
                  <button class="faq-toggle flex w-full items-center justify-between px-4 py-3 text-left text-sm font-medium text-slate-700 hover:text-slate-900 transition-colors">
                    Is there a free trial?
                    <svg class="faq-chevron h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="faq-answer">
                    <p class="px-4 pb-3 text-sm text-slate-600">Yes! vinQuality offers a 14-day free trial. Sign up at no cost and explore all features.</p>
                  </div>
                </div>
                <!-- FAQ 2 -->
                <div class="rounded-lg border border-slate-100">
                  <button class="faq-toggle flex w-full items-center justify-between px-4 py-3 text-left text-sm font-medium text-slate-700 hover:text-slate-900 transition-colors">
                    How long is a demo?
                    <svg class="faq-chevron h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="faq-answer">
                    <p class="px-4 pb-3 text-sm text-slate-600">Demos typically run 30 minutes. We'll walk through the features most relevant to your needs.</p>
                  </div>
                </div>
                <!-- FAQ 3 -->
                <div class="rounded-lg border border-slate-100">
                  <button class="faq-toggle flex w-full items-center justify-between px-4 py-3 text-left text-sm font-medium text-slate-700 hover:text-slate-900 transition-colors">
                    Can I import existing data?
                    <svg class="faq-chevron h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="faq-answer">
                    <p class="px-4 pb-3 text-sm text-slate-600">Absolutely. vinQuality supports CSV import for NCMRs, deviations, and other records.</p>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section class="py-20 sm:py-28 bg-gradient-to-br from-[#0D9488] via-[#0F766E] to-[#134E4A] gradient-animate">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal mx-auto max-w-3xl text-center">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">Ready to Get Started?</h2>
          <p class="mt-4 text-lg text-white/80">Join manufacturers worldwide who trust vinReliability for quality and reliability engineering.</p>
          <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="https://frontend-production-bec1.up.railway.app/register"
              class="inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-[#0D9488] shadow-lg hover:bg-slate-50 transition-colors w-full sm:w-auto"
            >
              Start Free Trial
            </a>
            <a
              href="/pricing"
              class="inline-flex items-center justify-center rounded-lg border border-white/30 px-6 py-3 text-base font-semibold text-white hover:bg-white/10 transition-colors w-full sm:w-auto"
            >
              View Pricing
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
