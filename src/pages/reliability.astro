---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "vinReliability",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Windows",
  "description": "Professional statistical analysis software with 60+ tools including Weibull analysis, SPC, DOE, hypothesis testing, and reliability engineering.",
  "url": "https://vinqms.com/reliability",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "price": "999",
    "priceValidUntil": "2027-12-31"
  },
  "publisher": {
    "@type": "Organization",
    "name": "vinReliability LLC"
  }
});

const categories = [
  {
    title: "Design of Experiments (DOE)",
    color: "#6366F1",
    desc: "Full and fractional factorial designs, response surface methodology, Taguchi methods, and mixture designs. Optimize products and processes with statistical rigor.",
    icon: "experiment"
  },
  {
    title: "Time Series & Forecasting",
    color: "#2563EB",
    desc: "ARIMA modeling, exponential smoothing, seasonal decomposition, and trend analysis. Forecast demand, failures, and performance over time.",
    icon: "trend"
  },
  {
    title: "Quality & SPC",
    color: "#0D9488",
    desc: "Process capability analysis (Cp, Cpk, Pp, Ppk), control charts (X-bar, R, S, P, C, U), gauge R&R, and measurement system analysis.",
    icon: "spc"
  },
  {
    title: "Statistics & Hypothesis Testing",
    color: "#F59E0B",
    desc: "t-tests, ANOVA, chi-square tests, non-parametric tests, confidence intervals, and sample size determination for rigorous decision-making.",
    icon: "hypothesis"
  },
  {
    title: "Multivariate Regression",
    color: "#10B981",
    desc: "Linear, polynomial, and logistic regression with residual analysis, prediction intervals, model comparison, and variable selection methods.",
    icon: "regression"
  },
  {
    title: "Reliability & Survival Analysis",
    color: "#EF4444",
    desc: "Weibull and lognormal analysis, Kaplan-Meier estimation, accelerated life testing, warranty prediction, and system reliability modeling.",
    icon: "reliability"
  }
];
---

<BaseLayout
  title="vinReliability — Professional Statistical Analysis Software | vinReliability LLC"
  description="60+ statistical analysis tools including Weibull, SPC, DOE, hypothesis testing, and reliability engineering. Professional alternative to Minitab at a fraction of the cost."
  keywords="statistical analysis software, Weibull analysis, SPC, process capability, DOE, design of experiments, reliability engineering, Minitab alternative, hypothesis testing"
  canonical="/reliability"
  jsonLd={jsonLd}
>
  <Header />

  <main>
    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden bg-[#0F172A]">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 right-1/4 w-96 h-96 bg-[#6366F1] rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-1/3 w-80 h-80 bg-[#84CC16] rounded-full blur-3xl"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
        <div class="reveal mx-auto max-w-4xl text-center">
          <span class="inline-flex items-center rounded-full border border-[#6366F1]/30 bg-[#6366F1]/10 px-4 py-1.5 text-sm font-medium text-[#A5B4FC]">
            60+ Statistical Analysis Tools
          </span>
          <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
            Professional Statistical<br />Analysis Made Easy
          </h1>
          <p class="mt-6 text-lg text-slate-300 sm:text-xl max-w-2xl mx-auto leading-relaxed">
            The complete toolkit for reliability engineers, quality engineers, and data analysts. From Weibull analysis to DOE, everything you need in one application.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="https://app.vinreliability.net/login"
              class="inline-flex items-center justify-center rounded-lg bg-[#6366F1] px-6 py-3 text-base font-semibold text-white shadow-lg shadow-[#6366F1]/25 hover:bg-[#4F46E5] transition-colors w-full sm:w-auto"
            >
              Start Free Trial
            </a>
            <a
              href="https://app.vinreliability.net/login"
              class="inline-flex items-center justify-center rounded-lg border border-slate-500 px-6 py-3 text-base font-semibold text-slate-200 hover:bg-white/5 transition-colors w-full sm:w-auto"
            >
              Sign In
            </a>
            <a
              href="#pricing"
              class="inline-flex items-center justify-center rounded-lg border border-slate-500 px-6 py-3 text-base font-semibold text-slate-200 hover:bg-white/5 transition-colors w-full sm:w-auto"
            >
              See Pricing
            </a>
          </div>
        </div>

        <!-- Hero SVG Mockup: Weibull + Process Capability -->
        <div class="reveal relative mt-16 mx-auto max-w-5xl hidden sm:block">
          <div class="rounded-xl border border-slate-700 bg-[#1E293B] shadow-2xl overflow-hidden">
            <!-- Browser chrome -->
            <div class="flex items-center gap-2 px-4 py-3 bg-[#0F172A] border-b border-slate-700">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
              </div>
              <div class="flex-1 mx-4">
                <div class="mx-auto max-w-md rounded-md bg-slate-800 px-3 py-1 text-xs text-slate-400 text-center">app.vinreliability.net</div>
              </div>
            </div>
            <!-- App mockup -->
            <div class="p-6 grid grid-cols-2 gap-6">
              <!-- Left: Weibull Plot -->
              <div class="rounded-lg bg-[#0F172A] p-4">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xs font-semibold text-slate-300">Weibull Probability Plot</span>
                  <span class="text-[10px] text-slate-500">Motor Winding Data</span>
                </div>
                <svg viewBox="0 0 300 200" class="w-full" xmlns="http://www.w3.org/2000/svg">
                  <!-- Grid -->
                  <line x1="40" y1="10" x2="40" y2="180" stroke="#334155" stroke-width="0.5"/>
                  <line x1="40" y1="180" x2="290" y2="180" stroke="#334155" stroke-width="0.5"/>
                  <line x1="40" y1="140" x2="290" y2="140" stroke="#334155" stroke-width="0.3" stroke-dasharray="3,3"/>
                  <line x1="40" y1="100" x2="290" y2="100" stroke="#334155" stroke-width="0.3" stroke-dasharray="3,3"/>
                  <line x1="40" y1="60" x2="290" y2="60" stroke="#334155" stroke-width="0.3" stroke-dasharray="3,3"/>
                  <line x1="40" y1="20" x2="290" y2="20" stroke="#334155" stroke-width="0.3" stroke-dasharray="3,3"/>
                  <!-- Y-axis labels -->
                  <text x="35" y="183" font-size="7" fill="#64748b" text-anchor="end">1%</text>
                  <text x="35" y="143" font-size="7" fill="#64748b" text-anchor="end">10%</text>
                  <text x="35" y="103" font-size="7" fill="#64748b" text-anchor="end">50%</text>
                  <text x="35" y="63" font-size="7" fill="#64748b" text-anchor="end">90%</text>
                  <text x="35" y="23" font-size="7" fill="#64748b" text-anchor="end">99%</text>
                  <!-- X-axis labels -->
                  <text x="70" y="193" font-size="7" fill="#64748b" text-anchor="middle">100</text>
                  <text x="140" y="193" font-size="7" fill="#64748b" text-anchor="middle">1000</text>
                  <text x="210" y="193" font-size="7" fill="#64748b" text-anchor="middle">5000</text>
                  <text x="270" y="193" font-size="7" fill="#64748b" text-anchor="middle">10000</text>
                  <!-- Fit line -->
                  <line x1="55" y1="175" x2="275" y2="25" stroke="#6366F1" stroke-width="2"/>
                  <!-- Confidence bands -->
                  <path d="M55,170 L275,15" stroke="#6366F1" stroke-width="0.5" stroke-dasharray="4,4" opacity="0.5"/>
                  <path d="M55,180 L275,35" stroke="#6366F1" stroke-width="0.5" stroke-dasharray="4,4" opacity="0.5"/>
                  <!-- Data points -->
                  <circle cx="65" cy="170" r="3" fill="#6366F1"/>
                  <circle cx="85" cy="160" r="3" fill="#6366F1"/>
                  <circle cx="100" cy="150" r="3" fill="#6366F1"/>
                  <circle cx="115" cy="140" r="3" fill="#6366F1"/>
                  <circle cx="130" cy="128" r="3" fill="#6366F1"/>
                  <circle cx="148" cy="115" r="3" fill="#6366F1"/>
                  <circle cx="162" cy="105" r="3" fill="#6366F1"/>
                  <circle cx="180" cy="92" r="3" fill="#6366F1"/>
                  <circle cx="198" cy="78" r="3" fill="#6366F1"/>
                  <circle cx="215" cy="65" r="3" fill="#6366F1"/>
                  <circle cx="240" cy="48" r="3" fill="#6366F1"/>
                  <circle cx="260" cy="35" r="3" fill="#6366F1"/>
                </svg>
                <div class="mt-2 grid grid-cols-3 gap-2 text-center">
                  <div class="rounded bg-[#1E293B] p-1.5">
                    <div class="text-[10px] text-slate-500">Shape (β)</div>
                    <div class="text-sm font-bold text-[#A5B4FC]">2.47</div>
                  </div>
                  <div class="rounded bg-[#1E293B] p-1.5">
                    <div class="text-[10px] text-slate-500">Scale (η)</div>
                    <div class="text-sm font-bold text-[#A5B4FC]">4,250</div>
                  </div>
                  <div class="rounded bg-[#1E293B] p-1.5">
                    <div class="text-[10px] text-slate-500">R² adj</div>
                    <div class="text-sm font-bold text-[#34D399]">0.987</div>
                  </div>
                </div>
              </div>
              <!-- Right: Process Capability -->
              <div class="rounded-lg bg-[#0F172A] p-4">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xs font-semibold text-slate-300">Process Capability Analysis</span>
                  <span class="text-[10px] text-slate-500">Shaft Diameter (mm)</span>
                </div>
                <svg viewBox="0 0 300 200" class="w-full" xmlns="http://www.w3.org/2000/svg">
                  <!-- Grid -->
                  <line x1="30" y1="170" x2="290" y2="170" stroke="#334155" stroke-width="0.5"/>
                  <line x1="30" y1="10" x2="30" y2="170" stroke="#334155" stroke-width="0.5"/>
                  <!-- Histogram bars -->
                  <rect x="55" y="155" width="18" height="15" fill="#6366F1" opacity="0.6" rx="1"/>
                  <rect x="75" y="140" width="18" height="30" fill="#6366F1" opacity="0.6" rx="1"/>
                  <rect x="95" y="115" width="18" height="55" fill="#6366F1" opacity="0.6" rx="1"/>
                  <rect x="115" y="85" width="18" height="85" fill="#6366F1" opacity="0.7" rx="1"/>
                  <rect x="135" y="45" width="18" height="125" fill="#6366F1" opacity="0.8" rx="1"/>
                  <rect x="155" y="25" width="18" height="145" fill="#6366F1" opacity="0.9" rx="1"/>
                  <rect x="175" y="40" width="18" height="130" fill="#6366F1" opacity="0.8" rx="1"/>
                  <rect x="195" y="80" width="18" height="90" fill="#6366F1" opacity="0.7" rx="1"/>
                  <rect x="215" y="110" width="18" height="60" fill="#6366F1" opacity="0.6" rx="1"/>
                  <rect x="235" y="140" width="18" height="30" fill="#6366F1" opacity="0.6" rx="1"/>
                  <rect x="255" y="155" width="18" height="15" fill="#6366F1" opacity="0.5" rx="1"/>
                  <!-- Bell curve (smooth Gaussian) -->
                  <path d="M50,170 C70,170 85,168 100,160 C115,152 125,138 135,115 C145,92 152,62 158,40 C161,30 163,24 165,22 C167,24 169,30 172,40 C178,62 185,92 195,115 C205,138 215,152 230,160 C245,168 260,170 275,170" stroke="#BFFF00" stroke-width="2" fill="none"/>
                  <!-- Spec limits -->
                  <line x1="60" y1="10" x2="60" y2="170" stroke="#EF4444" stroke-width="1.5" stroke-dasharray="5,3"/>
                  <line x1="265" y1="10" x2="265" y2="170" stroke="#EF4444" stroke-width="1.5" stroke-dasharray="5,3"/>
                  <text x="60" y="8" font-size="7" fill="#EF4444" text-anchor="middle">LSL</text>
                  <text x="265" y="8" font-size="7" fill="#EF4444" text-anchor="middle">USL</text>
                  <!-- Mean line -->
                  <line x1="163" y1="10" x2="163" y2="170" stroke="#BFFF00" stroke-width="1" stroke-dasharray="3,3" opacity="0.6"/>
                </svg>
                <div class="mt-2 grid grid-cols-4 gap-2 text-center">
                  <div class="rounded bg-[#1E293B] p-1.5">
                    <div class="text-[10px] text-slate-500">Cp</div>
                    <div class="text-sm font-bold text-[#34D399]">1.85</div>
                  </div>
                  <div class="rounded bg-[#1E293B] p-1.5">
                    <div class="text-[10px] text-slate-500">Cpk</div>
                    <div class="text-sm font-bold text-[#34D399]">1.67</div>
                  </div>
                  <div class="rounded bg-[#1E293B] p-1.5">
                    <div class="text-[10px] text-slate-500">Pp</div>
                    <div class="text-sm font-bold text-[#A5B4FC]">1.78</div>
                  </div>
                  <div class="rounded bg-[#1E293B] p-1.5">
                    <div class="text-[10px] text-slate-500">Ppk</div>
                    <div class="text-sm font-bold text-[#A5B4FC]">1.62</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FEATURE CATEGORIES ============ -->
    <section class="py-20 sm:py-28 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl">Comprehensive Analysis Toolkit</h2>
          <p class="mt-4 text-lg text-slate-600">Six powerful categories covering every aspect of statistical and reliability analysis.</p>
        </div>
        <div class="reveal mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {categories.map((cat) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-8 card-hover">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl" style={`background-color: ${cat.color}15;`}>
                {cat.icon === "experiment" && (
                  <svg class="h-6 w-6" style={`color: ${cat.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                  </svg>
                )}
                {cat.icon === "trend" && (
                  <svg class="h-6 w-6" style={`color: ${cat.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                  </svg>
                )}
                {cat.icon === "spc" && (
                  <svg class="h-6 w-6" style={`color: ${cat.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                  </svg>
                )}
                {cat.icon === "hypothesis" && (
                  <svg class="h-6 w-6" style={`color: ${cat.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                  </svg>
                )}
                {cat.icon === "regression" && (
                  <svg class="h-6 w-6" style={`color: ${cat.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
                  </svg>
                )}
                {cat.icon === "reliability" && (
                  <svg class="h-6 w-6" style={`color: ${cat.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                )}
              </div>
              <h3 class="mt-4 text-lg font-bold text-slate-900">{cat.title}</h3>
              <p class="mt-2 text-sm text-slate-600 leading-relaxed">{cat.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ COMPARISON vs MINITAB ============ -->
    <section class="py-20 sm:py-28 bg-slate-50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl">How We Compare</h2>
          <p class="mt-4 text-lg text-slate-600">Professional-grade analysis at a fraction of the cost.</p>
        </div>
        <div class="reveal mt-16 max-w-4xl mx-auto">
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
            <!-- Header Row -->
            <div class="grid grid-cols-3 bg-slate-50 border-b border-slate-200">
              <div class="p-4 sm:p-6 text-sm font-semibold text-slate-500">Feature</div>
              <div class="p-4 sm:p-6 text-center">
                <span class="text-sm font-bold text-[#6366F1]">vinReliability</span>
              </div>
              <div class="p-4 sm:p-6 text-center">
                <span class="text-sm font-bold text-slate-400">Minitab</span>
              </div>
            </div>
            <!-- Price -->
            <div class="grid grid-cols-3 border-b border-slate-100">
              <div class="p-4 sm:p-6 text-sm text-slate-700 font-medium">Annual Price</div>
              <div class="p-4 sm:p-6 text-center">
                <span class="text-lg font-extrabold text-[#6366F1]">$999</span>
                <span class="text-xs text-slate-500">/yr</span>
              </div>
              <div class="p-4 sm:p-6 text-center">
                <span class="text-lg font-extrabold text-slate-400">~$1,610</span>
                <span class="text-xs text-slate-500">/yr</span>
              </div>
            </div>
            <!-- Tools -->
            <div class="grid grid-cols-3 border-b border-slate-100">
              <div class="p-4 sm:p-6 text-sm text-slate-700 font-medium">Statistical Tools</div>
              <div class="p-4 sm:p-6 text-center text-sm text-slate-700">60+ tools</div>
              <div class="p-4 sm:p-6 text-center text-sm text-slate-500">Similar coverage</div>
            </div>
            <!-- Plots -->
            <div class="grid grid-cols-3 border-b border-slate-100">
              <div class="p-4 sm:p-6 text-sm text-slate-700 font-medium">Plot Output</div>
              <div class="p-4 sm:p-6 text-center">
                <span class="inline-flex items-center gap-1 text-sm text-[#6366F1] font-medium">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Interactive HTML
                </span>
              </div>
              <div class="p-4 sm:p-6 text-center text-sm text-slate-500">Static plots</div>
            </div>
            <!-- Lock-in -->
            <div class="grid grid-cols-3 border-b border-slate-100">
              <div class="p-4 sm:p-6 text-sm text-slate-700 font-medium">Subscription Lock-in</div>
              <div class="p-4 sm:p-6 text-center">
                <span class="inline-flex items-center gap-1 text-sm text-[#10B981] font-medium">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  No lock-in
                </span>
              </div>
              <div class="p-4 sm:p-6 text-center text-sm text-slate-500">Annual required</div>
            </div>
            <!-- Learning Curve -->
            <div class="grid grid-cols-3 border-b border-slate-100">
              <div class="p-4 sm:p-6 text-sm text-slate-700 font-medium">Learning Curve</div>
              <div class="p-4 sm:p-6 text-center">
                <span class="inline-flex items-center gap-1 text-sm text-[#6366F1] font-medium">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Guided workflows
                </span>
              </div>
              <div class="p-4 sm:p-6 text-center text-sm text-slate-500">Steep learning curve</div>
            </div>
            <!-- Report Export -->
            <div class="grid grid-cols-3 border-b border-slate-100">
              <div class="p-4 sm:p-6 text-sm text-slate-700 font-medium">Report Export</div>
              <div class="p-4 sm:p-6 text-center">
                <span class="inline-flex items-center gap-1 text-sm text-[#6366F1] font-medium">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  HTML + PDF
                </span>
              </div>
              <div class="p-4 sm:p-6 text-center text-sm text-slate-500">Static only</div>
            </div>
            <!-- Reliability Tools -->
            <div class="grid grid-cols-3 border-b border-slate-100">
              <div class="p-4 sm:p-6 text-sm text-slate-700 font-medium">Reliability-Specific Tools</div>
