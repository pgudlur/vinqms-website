---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "vinReliability LLC",
  "url": "https://vinqms.com",
  "logo": "https://vinqms.com/favicon.svg",
  "description": "Quality & Reliability Engineering Platform. From failure prediction to quality capture to reliability analysis.",
  "sameAs": [],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "support@vinreliability.net",
    "contactType": "customer support"
  },
  "offers": [
    {
      "@type": "Offer",
      "name": "vinQuality",
      "description": "Cloud-Based Quality Management System"
    },
    {
      "@type": "Offer",
      "name": "vinFMEA",
      "description": "FMEA & Control Plan Suite"
    },
    {
      "@type": "Offer",
      "name": "vinReliability",
      "description": "Statistical Analysis Software"
    }
  ]
});
---

<BaseLayout
  title="vinReliability — Quality & Reliability Engineering Platform"
  description="From failure prediction to quality capture to reliability analysis — one integrated platform by vinReliability LLC. vinQuality, vinFMEA, and vinReliability."
  keywords="quality management system, FMEA software, reliability engineering, QMS, CAPA, NCMR, statistical analysis, Weibull, SPC, ISO 9001, AS9100, 21 CFR Part 11"
  canonical="/"
  jsonLd={jsonLd}
>
  <Header />

  <main>
    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0F172A] to-[#1E293B]">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#0D9488] rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-[#6366F1] rounded-full blur-3xl"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
        <div class="reveal mx-auto max-w-4xl text-center">
          <span class="inline-flex items-center rounded-full border border-[#0D9488]/30 bg-[#0D9488]/10 px-4 py-1.5 text-sm font-medium text-[#5EEAD4]">
            Quality &amp; Reliability Engineering Platform
          </span>
          <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
            Engineering Excellence,<br />End to End.
          </h1>
          <p class="mt-6 text-lg text-slate-300 sm:text-xl max-w-2xl mx-auto leading-relaxed">
            From failure prediction to quality capture to reliability analysis &mdash; one integrated platform by vinReliability LLC.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/pricing"
              class="inline-flex items-center justify-center rounded-lg bg-[#0D9488] px-6 py-3 text-base font-semibold text-white shadow-lg shadow-[#0D9488]/25 hover:bg-[#0F766E] transition-colors w-full sm:w-auto"
            >
              Explore Products
            </a>
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-lg border border-slate-500 px-6 py-3 text-base font-semibold text-slate-200 hover:bg-white/5 transition-colors w-full sm:w-auto"
            >
              Contact Sales
            </a>
          </div>
          <div class="mt-12 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-slate-400">
            <span>ISO 9001</span>
            <span class="text-slate-600">&middot;</span>
            <span>AS9100</span>
            <span class="text-slate-600">&middot;</span>
            <span>21 CFR Part 11</span>
            <span class="text-slate-600">&middot;</span>
            <span>IATF 16949</span>
            <span class="text-slate-600">&middot;</span>
            <span>AIAG-VDA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PRODUCT SHOWCASE ============ -->
    <section class="py-20 sm:py-28 bg-slate-50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl">Three Products, One Platform</h2>
          <p class="mt-4 text-lg text-slate-600">Everything you need for quality and reliability engineering, working together seamlessly.</p>
        </div>
        <div class="reveal mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
          <!-- vinQuality -->
          <div class="relative rounded-2xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="absolute inset-x-0 top-0 h-1 rounded-t-2xl bg-[#0D9488]"></div>
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#0D9488]/10">
              <svg class="h-6 w-6 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">vinQuality</h3>
            <p class="mt-1 text-sm font-medium text-[#0D9488]">Cloud-Based Quality Management System</p>
            <!-- Mini app preview -->
            <div class="mt-4 rounded-lg overflow-hidden border border-slate-200 bg-slate-50">
              <svg viewBox="0 0 320 140" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
                <rect width="320" height="140" fill="#F8FAFC"/>
                <!-- Mini sidebar -->
                <rect width="60" height="140" fill="#0F172A"/>
                <rect x="8" y="8" width="44" height="6" rx="3" fill="#0D9488" fill-opacity="0.4"/>
                <rect x="8" y="22" width="44" height="5" rx="2.5" fill="#0D9488" fill-opacity="0.2"/>
                <rect x="8" y="34" width="44" height="5" rx="2.5" fill="#475569" fill-opacity="0.3"/>
                <rect x="8" y="46" width="44" height="5" rx="2.5" fill="#475569" fill-opacity="0.3"/>
                <rect x="8" y="58" width="44" height="5" rx="2.5" fill="#475569" fill-opacity="0.3"/>
                <!-- Stat cards -->
                <rect x="70" y="8" width="56" height="32" rx="4" fill="white" stroke="#E2E8F0" stroke-width="0.5"/>
                <text x="78" y="20" font-family="system-ui" font-size="5" fill="#64748B">Open NCMRs</text>
                <text x="78" y="32" font-family="system-ui" font-size="10" font-weight="700" fill="#0F172A">24</text>
                <rect x="132" y="8" width="56" height="32" rx="4" fill="white" stroke="#E2E8F0" stroke-width="0.5"/>
                <text x="140" y="20" font-family="system-ui" font-size="5" fill="#64748B">Active CAPAs</text>
                <text x="140" y="32" font-family="system-ui" font-size="10" font-weight="700" fill="#0F172A">12</text>
                <rect x="194" y="8" width="56" height="32" rx="4" fill="white" stroke="#E2E8F0" stroke-width="0.5"/>
                <text x="202" y="20" font-family="system-ui" font-size="5" fill="#64748B">SLA Comp.</text>
                <text x="202" y="32" font-family="system-ui" font-size="10" font-weight="700" fill="#0D9488">94%</text>
                <rect x="256" y="8" width="56" height="32" rx="4" fill="white" stroke="#E2E8F0" stroke-width="0.5"/>
                <text x="264" y="20" font-family="system-ui" font-size="5" fill="#64748B">Pending</text>
                <text x="264" y="32" font-family="system-ui" font-size="10" font-weight="700" fill="#F59E0B">7</text>
                <!-- Table rows -->
                <rect x="70" y="48" width="242" height="84" rx="4" fill="white" stroke="#E2E8F0" stroke-width="0.5"/>
                <rect x="70" y="48" width="242" height="14" rx="0" fill="#F8FAFC"/>
                <text x="78" y="58" font-family="system-ui" font-size="5" font-weight="600" fill="#64748B">NCMR #</text>
                <text x="140" y="58" font-family="system-ui" font-size="5" font-weight="600" fill="#64748B">TITLE</text>
                <text x="240" y="58" font-family="system-ui" font-size="5" font-weight="600" fill="#64748B">STATUS</text>
                <line x1="70" y1="62" x2="312" y2="62" stroke="#F1F5F9" stroke-width="0.5"/>
                <text x="78" y="74" font-family="system-ui" font-size="5" fill="#0D9488">NCMR-2026-00142</text>
                <text x="140" y="74" font-family="system-ui" font-size="5" fill="#334155">Dimensional out-of-spec</text>
                <rect x="240" y="68" width="30" height="10" rx="5" fill="#FEF3C7"/>
                <text x="245" y="76" font-family="system-ui" font-size="4" font-weight="600" fill="#D97706">Review</text>
                <line x1="70" y1="80" x2="312" y2="80" stroke="#F1F5F9" stroke-width="0.5"/>
                <text x="78" y="92" font-family="system-ui" font-size="5" fill="#0D9488">NCMR-2026-00141</text>
                <text x="140" y="92" font-family="system-ui" font-size="5" fill="#334155">Surface finish non-conf.</text>
                <rect x="240" y="86" width="30" height="10" rx="5" fill="#DBEAFE"/>
                <text x="246" y="94" font-family="system-ui" font-size="4" font-weight="600" fill="#2563EB">CAPA</text>
                <line x1="70" y1="98" x2="312" y2="98" stroke="#F1F5F9" stroke-width="0.5"/>
                <text x="78" y="110" font-family="system-ui" font-size="5" fill="#0D9488">NCMR-2026-00140</text>
                <text x="140" y="110" font-family="system-ui" font-size="5" fill="#334155">Material cert mismatch</text>
                <rect x="240" y="104" width="30" height="10" rx="5" fill="#D1FAE5"/>
                <text x="244" y="112" font-family="system-ui" font-size="4" font-weight="600" fill="#059669">Closed</text>
                <line x1="70" y1="116" x2="312" y2="116" stroke="#F1F5F9" stroke-width="0.5"/>
                <text x="78" y="128" font-family="system-ui" font-size="5" fill="#0D9488">NCMR-2026-00139</text>
                <text x="140" y="128" font-family="system-ui" font-size="5" fill="#334155">Weld porosity on A-12</text>
                <rect x="240" y="122" width="30" height="10" rx="5" fill="#FEF3C7"/>
                <text x="248" y="130" font-family="system-ui" font-size="4" font-weight="600" fill="#D97706">Open</text>
              </svg>
            </div>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                NCMR &amp; Deviation Tracking
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                CAPA &amp; SCAR Management
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                21 CFR Part 11 E-Signatures
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
