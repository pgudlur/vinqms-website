            <div class="mt-4 rounded-lg overflow-hidden border border-slate-200 bg-slate-50">
              <svg viewBox="0 0 320 140" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
                <rect width="320" height="140" fill="#F8FAFC"/>
                <!-- Toolbar -->
                <rect width="320" height="22" fill="#1E293B"/>
                <text x="8" y="14" font-family="system-ui" font-size="6" font-weight="600" fill="white">vinFMEA Pro</text>
                <!-- Tabs -->
                <rect x="80" y="4" width="36" height="14" rx="3" fill="#334155"/>
                <text x="86" y="14" font-family="system-ui" font-size="5" fill="#94A3B8">SFMEA</text>
                <rect x="120" y="4" width="38" height="14" rx="3" fill="#334155"/>
                <text x="125" y="14" font-family="system-ui" font-size="5" fill="#94A3B8">DFMEA</text>
                <rect x="162" y="4" width="38" height="14" rx="3" fill="#2563EB"/>
