---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "vinReliability LLC",
  "url": "https://vinqms.com",
  "logo": "https://vinqms.com/favicon.svg",
  "description": "Quality & Reliability Engineering Platform. From failure prediction to quality capture to reliability analysis.",
  "sameAs": [],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "support@vinreliability.net",
    "contactType": "customer support"
  },
  "offers": [
    {
      "@type": "Offer",
      "name": "vinQuality",
      "description": "Cloud-Based Quality Management System"
    },
    {
      "@type": "Offer",
      "name": "vinFMEA",
      "description": "FMEA & Control Plan Suite"
    },
    {
      "@type": "Offer",
      "name": "vinReliability",
      "description": "Statistical Analysis Software"
    }
  ]
});
---

<BaseLayout
  title="vinReliability — Quality & Reliability Engineering Platform"
  description="From failure prediction to quality capture to reliability analysis — one integrated platform by vinReliability LLC. vinQuality, vinFMEA, and vinReliability."
  keywords="quality management system, FMEA software, reliability engineering, QMS, CAPA, NCMR, statistical analysis, Weibull, SPC, ISO 9001, AS9100, 21 CFR Part 11"
  canonical="/"
  jsonLd={jsonLd}
>
  <Header />

  <main>
    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0F172A] to-[#1E293B]">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#0D9488] rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-[#6366F1] rounded-full blur-3xl"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
        <div class="reveal mx-auto max-w-4xl text-center">
          <span class="inline-flex items-center rounded-full border border-[#0D9488]/30 bg-[#0D9488]/10 px-4 py-1.5 text-sm font-medium text-[#5EEAD4]">
            Quality &amp; Reliability Engineering Platform
          </span>
          <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
            Engineering Excellence,<br />End to End.
          </h1>
          <p class="mt-6 text-lg text-slate-300 sm:text-xl max-w-2xl mx-auto leading-relaxed">
            From failure prediction to quality capture to reliability analysis &mdash; one integrated platform by vinReliability LLC.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/pricing"
              class="inline-flex items-center justify-center rounded-lg bg-[#0D9488] px-6 py-3 text-base font-semibold text-white shadow-lg shadow-[#0D9488]/25 hover:bg-[#0F766E] transition-colors w-full sm:w-auto"
            >
              Explore Products
            </a>
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-lg border border-slate-500 px-6 py-3 text-base font-semibold text-slate-200 hover:bg-white/5 transition-colors w-full sm:w-auto"
            >
              Contact Sales
            </a>
          </div>
          <div class="mt-12 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-slate-400">
            <span>ISO 9001</span>
            <span class="text-slate-600">&middot;</span>
            <span>AS9100</span>
            <span class="text-slate-600">&middot;</span>
            <span>21 CFR Part 11</span>
            <span class="text-slate-600">&middot;</span>
            <span>IATF 16949</span>
            <span class="text-slate-600">&middot;</span>
            <span>AIAG-VDA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PRODUCT SHOWCASE ============ -->
    <section class="py-20 sm:py-28 bg-slate-50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl">Three Products, One Platform</h2>
          <p class="mt-4 text-lg text-slate-600">Everything you need for quality and reliability engineering, working together seamlessly.</p>
        </div>
        <div class="reveal mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
          <!-- vinQuality -->
          <div class="relative rounded-2xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="absolute inset-x-0 top-0 h-1 rounded-t-2xl bg-[#0D9488]"></div>
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#0D9488]/10">
              <svg class="h-6 w-6 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">vinQuality</h3>
            <p class="mt-1 text-sm font-medium text-[#0D9488]">Cloud-Based Quality Management System</p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                NCMR &amp; Deviation Tracking
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                CAPA &amp; SCAR Management
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                21 CFR Part 11 E-Signatures
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Real-Time Analytics Dashboard
              </li>
            </ul>
            <a href="/quality" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-[#0D9488] hover:text-[#0F766E] transition-colors">
              Learn More
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>

          <!-- vinFMEA -->
          <div class="relative rounded-2xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="absolute inset-x-0 top-0 h-1 rounded-t-2xl bg-[#2563EB]"></div>
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#2563EB]/10">
              <svg class="h-6 w-6 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
            </div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">vinFMEA</h3>
            <p class="mt-1 text-sm font-medium text-[#2563EB]">FMEA &amp; Control Plan Suite</p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                System, Design &amp; Process FMEA
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                AIAG-VDA 7-Step Methodology
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                4-Level Traceability
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                ISO 26262 Functional Safety
              </li>
            </ul>
            <a href="/fmea" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-[#2563EB] hover:text-[#1D4ED8] transition-colors">
              Learn More
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>

          <!-- vinReliability -->
          <div class="relative rounded-2xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="absolute inset-x-0 top-0 h-1 rounded-t-2xl bg-[#6366F1]"></div>
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#6366F1]/10">
              <svg class="h-6 w-6 text-[#6366F1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">vinReliability</h3>
            <p class="mt-1 text-sm font-medium text-[#6366F1]">Statistical Analysis Software</p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#6366F1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Weibull &amp; Life Data Analysis
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#6366F1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                SPC &amp; Process Capability
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#6366F1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Design of Experiments (DOE)
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#6366F1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                60+ Statistical Tools
              </li>
            </ul>
            <a href="/reliability" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-[#6366F1] hover:text-[#4F46E5] transition-colors">
              Learn More
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ WHY VINRELIABILITY ============ -->
    <section class="py-20 sm:py-28 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl">Why vinReliability</h2>
          <p class="mt-4 text-lg text-slate-600">Built by engineers, for engineers. We understand your workflow.</p>
        </div>
        <div class="reveal mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2">
          <!-- One Platform -->
          <div class="rounded-2xl border border-slate-200 bg-white p-8 hover:shadow-md transition-shadow">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#0D9488]/10">
              <svg class="h-6 w-6 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-slate-900">One Platform, Complete Coverage</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">From FMEA risk analysis through production quality to reliability prediction. No more juggling disconnected tools.</p>
          </div>

          <!-- Regulatory Compliance -->
          <div class="rounded-2xl border border-slate-200 bg-white p-8 hover:shadow-md transition-shadow">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#0D9488]/10">
              <svg class="h-6 w-6 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-slate-900">Regulatory Compliance Built In</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">FDA 21 CFR Part 11, ISO 9001, AS9100, IATF 16949 ready out of the box. No expensive add-ons required.</p>
          </div>

          <!-- Closed-Loop Quality -->
          <div class="rounded-2xl border border-slate-200 bg-white p-8 hover:shadow-md transition-shadow">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#0D9488]/10">
              <svg class="h-6 w-6 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-slate-900">Closed-Loop Quality</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">Predicted failure modes automatically link to real-world non-conformances. Continuously improve with data-driven insights.</p>
          </div>

          <!-- Affordable & Modular -->
          <div class="rounded-2xl border border-slate-200 bg-white p-8 hover:shadow-md transition-shadow">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#0D9488]/10">
              <svg class="h-6 w-6 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-slate-900">Affordable &amp; Modular</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">Pay only for what you need. A fraction of the cost of enterprise quality suites, with no compromise on capability.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ ECOSYSTEM / CLOSED LOOP ============ -->
    <section class="py-20 sm:py-28 bg-[#0F172A]">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">The Closed-Loop Ecosystem</h2>
          <p class="mt-4 text-lg text-slate-400">Predict failures, detect issues, and continuously improve &mdash; all connected.</p>
        </div>

        <!-- 3-Column Flow -->
        <div class="reveal mt-16 grid grid-cols-1 gap-6 md:grid-cols-3 items-center">
          <div class="rounded-2xl border border-[#2563EB]/30 bg-[#1E293B] p-8 text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#2563EB]/10">
              <svg class="h-7 w-7 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-white">vinFMEA</h3>
            <p class="mt-1 text-sm font-medium text-[#60A5FA]">Predict</p>
            <p class="mt-3 text-sm text-slate-400">Identify and prioritize potential failure modes before they occur.</p>
          </div>

          <!-- Arrow (hidden on mobile) -->
          <div class="hidden md:flex items-center justify-center -mx-6">
            <div class="flex items-center w-full">
              <div class="flex-1 h-0.5 bg-gradient-to-r from-[#2563EB] to-[#0D9488]"></div>
              <svg class="h-5 w-5 text-[#0D9488] -ml-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
            </div>
          </div>

          <!-- Mobile arrow -->
          <div class="flex md:hidden justify-center">
            <svg class="h-6 w-6 text-slate-500 rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </div>

          <div class="rounded-2xl border border-[#0D9488]/30 bg-[#1E293B] p-8 text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#0D9488]/10">
              <svg class="h-7 w-7 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-white">vinQuality</h3>
            <p class="mt-1 text-sm font-medium text-[#5EEAD4]">Detect &amp; Resolve</p>
            <p class="mt-3 text-sm text-slate-400">Capture non-conformances, manage CAPAs, and track corrective actions.</p>
          </div>

          <!-- Arrow (hidden on mobile) -->
          <div class="hidden md:flex items-center justify-center -mx-6">
            <div class="flex items-center w-full">
              <div class="flex-1 h-0.5 bg-gradient-to-r from-[#0D9488] to-[#6366F1]"></div>
              <svg class="h-5 w-5 text-[#6366F1] -ml-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
            </div>
          </div>

          <!-- Mobile arrow -->
          <div class="flex md:hidden justify-center">
            <svg class="h-6 w-6 text-slate-500 rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </div>

          <div class="rounded-2xl border border-[#6366F1]/30 bg-[#1E293B] p-8 text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#6366F1]/10">
              <svg class="h-7 w-7 text-[#6366F1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-white">vinReliability</h3>
            <p class="mt-1 text-sm font-medium text-[#A5B4FC]">Analyze</p>
            <p class="mt-3 text-sm text-slate-400">Statistically analyze reliability data to drive continuous improvement.</p>
          </div>
        </div>

        <!-- 4-Step Closed Loop -->
        <div class="reveal mt-16 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-xl border-l-4 border-[#2563EB] bg-[#1E293B] p-6">
            <span class="text-2xl font-extrabold text-[#2563EB]">1</span>
