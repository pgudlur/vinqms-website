                <text x="150" y="32" font-family="system-ui" font-size="4.5" font-weight="600" fill="#1E40AF">S</text>
                <text x="164" y="32" font-family="system-ui" font-size="4.5" font-weight="600" fill="#1E40AF">O</text>
                <text x="178" y="32" font-family="system-ui" font-size="4.5" font-weight="600" fill="#1E40AF">D</text>
                <text x="192" y="32" font-family="system-ui" font-size="4.5" font-weight="600" fill="#1E40AF">AP</text>
                <text x="212" y="32" font-family="system-ui" font-size="4.5" font-weight="600" fill="#1E40AF">Action Item</text>
                <text x="280" y="32" font-family="system-ui" font-size="4.5" font-weight="600" fill="#1E40AF">Status</text>
                <!-- Data rows -->
                <rect x="0" y="36" width="320" height="13" fill="white"/>
                <text x="6" y="45" font-family="system-ui" font-size="4.5" fill="#334155">1</text>
                <text x="26" y="45" font-family="system-ui" font-size="4.5" fill="#334155">CNC Machining</text>
