            <a href="/contact" class="mt-8 block w-full rounded-lg bg-[#0D9488] px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-[#0F766E] transition-colors">
              Start Free Trial
            </a>
          </div>

          <!-- Deviations -->
          <div class="reveal reveal-d2 relative rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="text-lg font-semibold text-slate-900">Deviations</h3>
            <p class="text-sm text-slate-500">Deviation Management</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-slate-900">$45</span>
              <span class="text-sm text-slate-500">/seat/mo</span>
            </div>
            <p class="mt-1 text-xs text-slate-400">or $450/seat/yr</p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-2 text-sm text-slate-700">
                <svg class="h-5 w-5 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Process deviation tracking
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-700">
                <svg class="h-5 w-5 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Impact assessment
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-700">
