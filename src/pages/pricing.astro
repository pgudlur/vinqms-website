            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-slate-900">$45</span>
              <span class="text-sm text-slate-500">/seat/mo</span>
            </div>
            <p class="mt-1 text-xs text-slate-400">or $450/seat/yr</p>
