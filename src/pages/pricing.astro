    <!-- vinFMEA Team Slider Script -->
    <script>
      (function() {
        var slider = document.getElementById('fmea-seats');
        var countEl = document.getElementById('fmea-count');
        var perSeatEl = document.getElementById('fmea-per-seat');
        var discountEl = document.getElementById('fmea-discount');
        var totalEl = document.getElementById('fmea-total');
        var totalLabelEl = document.getElementById('fmea-total-label');
        var minusBtn = document.getElementById('fmea-minus');
        var plusBtn = document.getElementById('fmea-plus');
        var presets = document.querySelectorAll('.fmea-preset');
        var BASE = 1799;

        function getPerSeat(seats) {
          if (seats <= 4) return 1799;
          if (seats <= 9) return 1599;
          if (seats <= 24) return 1399;
          return 1199;
        }

        function fmt(n) {
          return '$' + n.toLocaleString('en-US');
        }

        function update(seats) {
          seats = Math.max(2, Math.min(50, seats));
          slider.value = seats;
          countEl.textContent = seats;
          var per = getPerSeat(seats);
          var total = per * seats;
          var pct = Math.round((1 - per / BASE) * 100);
          perSeatEl.textContent = fmt(per) + '/yr';
          if (pct > 0) {
            discountEl.textContent = pct + '% off';
            discountEl.style.display = '';
          } else {
            discountEl.style.display = 'none';
          }
          totalEl.textContent = fmt(total) + '/yr';
          totalLabelEl.textContent = seats + (seats === 1 ? ' seat' : ' seats');

          presets.forEach(function(btn) {
            var s = parseInt(btn.dataset.seats);
            if (s === seats) {
              btn.classList.add('border-[#0D9488]', 'bg-teal-50');
              btn.classList.remove('border-slate-200');
            } else {
              btn.classList.remove('border-[#0D9488]', 'bg-teal-50');
              btn.classList.add('border-slate-200');
            }
          });
        }

        slider.addEventListener('input', function() { update(parseInt(this.value)); });
        minusBtn.addEventListener('click', function() { update(parseInt(slider.value) - 1); });
        plusBtn.addEventListener('click', function() { update(parseInt(slider.value) + 1); });
        presets.forEach(function(btn) {
          btn.addEventListener('click', function() { update(parseInt(this.dataset.seats)); });
        });
      })();
    </script>

    <!-- vinFMEA Stripe Checkout Script -->
    <script>
      (function() {
        var FMEA_API = 'https://vinfmea-api-production.up.railway.app';
        var proBtn = document.getElementById('fmea-pro-checkout');
        var teamBtn = document.getElementById('fmea-team-checkout');
        var slider = document.getElementById('fmea-seats');

        async function checkout(plan, quantity) {
          var btn = plan === 'team_annual' ? teamBtn : proBtn;
          var origText = btn.textContent;
          btn.textContent = 'Redirecting...';
          btn.disabled = true;
          try {
            var res = await fetch(FMEA_API + '/api/stripe/create-checkout-session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ plan: plan, quantity: quantity })
            });
            var data = await res.json();
            if (data.checkout_url) {
              window.location.href = data.checkout_url;
            } else {
              throw new Error('No checkout URL');
            }
          } catch (e) {
            alert('Unable to start checkout. Please try again or contact support.');
            btn.textContent = origText;
            btn.disabled = false;
          }
        }

        proBtn.addEventListener('click', function() {
          checkout('professional_annual', 1);
        });

        teamBtn.addEventListener('click', function() {
          var seats = parseInt(slider.value) || 5;
          checkout('team_annual', seats);
        });
      })();
    </script>

