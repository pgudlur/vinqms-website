            <p class="text-sm text-slate-500">Supplier Corrective Actions</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-slate-900">$35</span>
              <span class="text-sm text-slate-500">/seat/mo</span>
            </div>
            <p class="mt-1 text-xs text-slate-400">or $350/seat/yr</p>
            <ul class="mt-6 space-y-3">
