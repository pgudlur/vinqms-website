---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Pricing — vinReliability"
  description="Transparent pricing for vinQuality, vinFMEA, and vinReliability. Choose the plan that fits your team."
  keywords="vinQuality pricing, vinFMEA pricing, vinReliability pricing, QMS pricing, FMEA software pricing"
  canonical="/pricing"
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-b from-slate-50 to-white py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal">
          <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
            Simple, Transparent Pricing
          </h1>
          <p class="mt-4 max-w-2xl mx-auto text-lg text-slate-600">
            Flexible plans for teams of every size. Start with a free trial, upgrade when you're ready, and cancel anytime.
          </p>
        </div>
      </div>
    </section>

    <!-- vinQuality Pricing -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">vinQuality — Quality Management System</h2>
          <p class="mt-3 text-lg text-slate-600">Pick only the modules you need. Mix and match to build your ideal QMS.</p>
        </div>

        <!-- Multi-module discount badges -->
        <div class="reveal flex flex-wrap items-center justify-center gap-3 mb-10">
          <span class="inline-flex items-center rounded-full bg-teal-50 border border-teal-200 px-4 py-1.5 text-sm font-medium text-teal-700">2+ modules: 15% off</span>
          <span class="inline-flex items-center rounded-full bg-teal-50 border border-teal-200 px-4 py-1.5 text-sm font-medium text-teal-700">3+ modules: 25% off</span>
          <span class="inline-flex items-center rounded-full bg-[#0D9488] px-4 py-1.5 text-sm font-semibold text-white">All 6 modules: 35% off</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          <!-- NCMR -->
          <div class="reveal reveal-d1 relative rounded-2xl border-2 border-[#0D9488] bg-white p-6 shadow-lg hover:shadow-xl transition-shadow">
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-[#0D9488] px-3 py-1 text-xs font-semibold text-white">Most Popular</span>
            <h3 class="text-lg font-semibold text-slate-900">NCMR</h3>
            <p class="text-sm text-slate-500">Non-Conformance Reports</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-slate-900">$55</span>
              <span class="text-sm text-slate-500">/seat/mo</span>
            </div>
            <p class="mt-1 text-xs text-slate-400">or $550/seat/yr</p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-2 text-sm text-slate-700">
                <svg class="h-5 w-5 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Create &amp; track NCMRs
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-700">
                <svg class="h-5 w-5 shrink-0 text-[#0D9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Configurable workflows
              </li>
              <li class="flex items-start gap-2 text-sm text-slate-700">
