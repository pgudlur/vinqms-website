            </div>
          </div>
          <div class="reveal reveal-d5 rounded-xl border border-slate-200 bg-white">
            <button class="faq-toggle w-full flex items-center justify-between p-5 text-left">
              <span class="text-sm font-semibold text-slate-900">What languages are supported?</span>
