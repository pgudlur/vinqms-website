---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "vinQuality",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": "Cloud-based Quality Management System for manufacturers. NCMR, CAPA, SCAR, Deviations, 21 CFR Part 11 compliance, and real-time analytics.",
  "url": "https://vinqms.com/quality",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "USD",
    "lowPrice": "25",
    "highPrice": "55",
    "offerCount": "6"
  },
  "publisher": {
    "@type": "Organization",
    "name": "vinReliability LLC"
  }
});

const features = [
  {
    title: "21 CFR Part 11 E-Signatures",
    description: "FDA-compliant electronic signatures with meaning statements, password re-authentication, and tamper-evident audit records.",
    icon: "signature"
  },
  {
    title: "Multi-Step Approval Workflows",
    description: "Configurable approval chains with parallel and sequential routing, escalation rules, and delegation support.",
    icon: "workflow"
  },
  {
    title: "SLA Tracking & Breach Alerts",
    description: "Set response and resolution SLAs per record type. Automatic escalation emails when deadlines approach or breach.",
    icon: "clock"
  },
  {
    title: "Record Locking",
    description: "Prevent concurrent edits with optimistic locking. Clear lock indicators and automatic release on timeout.",
    icon: "lock"
  },
  {
    title: "Hash Chain Audit Trail",
    description: "SHA-256 cryptographic hash chain ensures every change is tamper-evident and fully traceable for regulatory audits.",
    icon: "chain"
  },
  {
    title: "Role-Based Access Control",
    description: "Granular permissions by role, department, and module. Ensure users only see and do what they're authorized for.",
    icon: "users"
  },
  {
    title: "CSV & PDF Report Exports",
    description: "Export any report or record set to CSV or professionally formatted PDF. Schedule recurring report delivery.",
    icon: "download"
  },
  {
    title: "Real-Time Dashboards",
    description: "Live metrics, trend charts, and KPI tracking. Customizable widgets for quality managers and executives.",
    icon: "chart"
  },
  {
    title: "Calibration Management",
    description: "Track instrument calibration schedules, certificates, and due dates. Automated reminders for upcoming calibrations.",
    icon: "calibration"
  }
];

const modules = [
  { name: "NCMR", full: "Non-Conformance Reports", color: "#EF4444", desc: "Create, track, and resolve non-conforming material reports with full traceability and disposition workflows." },
  { name: "Deviations", full: "Deviation Management", color: "#F59E0B", desc: "Document process deviations, assess impact, and manage approvals with configurable workflow routing." },
  { name: "CAPA", full: "Corrective & Preventive Actions", color: "#2563EB", desc: "Root cause analysis, corrective action planning, effectiveness verification, and closure tracking." },
  { name: "SCAR", full: "Supplier Corrective Actions", color: "#7C3AED", desc: "Issue supplier corrective action requests, track responses, and monitor supplier quality performance." },
  { name: "Analytics", full: "Analytics & Reporting", color: "#0D9488", desc: "Real-time dashboards, trend analysis, Pareto charts, and scheduled report generation with export." },
  { name: "Inspection", full: "Inspection & Calibration", color: "#10B981", desc: "Manage inspection plans, record results, track calibration schedules, and generate certificates." },
  { name: "Supplier Mgmt", full: "Supplier Management", color: "#6366F1", desc: "Approved supplier lists, performance scorecards, qualification tracking, and risk assessments." }
];
---

<BaseLayout
  title="vinQuality — Cloud-Based Quality Management System | vinReliability"
  description="Enterprise QMS with zero overhead. NCMR, CAPA, SCAR, Deviations, 21 CFR Part 11 e-signatures, SHA-256 audit trail, and real-time dashboards."
  keywords="quality management system, QMS, NCMR, CAPA, SCAR, deviation management, 21 CFR Part 11, e-signatures, audit trail, ISO 9001"
  canonical="/quality"
  jsonLd={jsonLd}
>
  <Header />

  <main>
    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden bg-white">
      <div class="absolute inset-0 opacity-5">
        <div class="absolute top-0 right-0 w-96 h-96 bg-[#0D9488] rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-80 h-80 bg-[#0D9488] rounded-full blur-3xl"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
        <div class="reveal mx-auto max-w-4xl text-center">
          <span class="inline-flex items-center rounded-full border border-[#0D9488]/20 bg-[#0D9488]/5 px-4 py-1.5 text-sm font-medium text-[#0D9488]">
            Quality Management System
          </span>
          <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
            Enterprise QMS,<br />Zero Overhead.
          </h1>
          <p class="mt-6 text-lg text-slate-600 sm:text-xl max-w-2xl mx-auto leading-relaxed">
            Modular, cloud-based quality management built for manufacturers. From NCMRs to CAPAs, manage every quality event with compliance baked in.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="https://frontend-production-bec1.up.railway.app/register"
              class="inline-flex items-center justify-center rounded-lg bg-[#0D9488] px-6 py-3 text-base font-semibold text-white shadow-lg shadow-[#0D9488]/25 hover:bg-[#0F766E] transition-colors w-full sm:w-auto"
            >
              Start Free Trial
            </a>
            <a
              href="https://frontend-production-bec1.up.railway.app/login"
              class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-6 py-3 text-base font-semibold text-slate-700 hover:bg-slate-50 transition-colors w-full sm:w-auto"
            >
              Sign In
            </a>
            <a
              href="/pricing"
              class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-6 py-3 text-base font-semibold text-slate-700 hover:bg-slate-50 transition-colors w-full sm:w-auto"
            >
              See Pricing
            </a>
          </div>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-slate-500">
            <span>21 CFR Part 11</span>
            <span class="text-slate-300">&middot;</span>
            <span>SHA-256 Audit Trail</span>
            <span class="text-slate-300">&middot;</span>
            <span>Role-Based Access</span>
          </div>
        </div>

        <!-- App Mockup -->
        <div class="reveal hidden sm:block mt-16 mx-auto max-w-5xl">
          <div class="rounded-xl overflow-hidden shadow-2xl ring-1 ring-slate-900/10 bg-slate-900">
            <!-- Browser Chrome -->
            <div class="flex items-center gap-2 px-4 py-3 bg-slate-800 border-b border-slate-700">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
