              <!-- Bars -->
              <rect x="792" y="395" width="14" height="45" rx="2" fill="#0D9488" fill-opacity="0.3"/>
              <rect x="814" y="385" width="14" height="55" rx="2" fill="#0D9488" fill-opacity="0.4"/>
              <rect x="836" y="375" width="14" height="65" rx="2" fill="#0D9488" fill-opacity="0.5"/>
