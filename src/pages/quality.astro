              <text x="884" y="232" font-family="system-ui" font-size="9" fill="#64748B">CAPA (13%)</text>

              <!-- Trend Chart -->
              <rect x="764" y="320" width="168" height="144" rx="10" fill="white" stroke="#E2E8F0" stroke-width="1"/>
              <text x="780" y="344" font-family="system-ui" font-size="11" font-weight="600" fill="#0F172A">Monthly Trend</text>
              <!-- Chart area -->
              <line x1="784" y1="440" x2="912" y2="440" stroke="#E2E8F0" stroke-width="1"/>
