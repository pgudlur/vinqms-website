              <!-- Row 4 -->
              <line x1="224" y1="344" x2="752" y2="344" stroke="#F1F5F9" stroke-width="1"/>
              <text x="240" y="364" font-family="system-ui" font-size="11" fill="#0D9488" font-weight="500">NCMR-2026-00139</text>
              <text x="340" y="364" font-family="system-ui" font-size="11" fill="#334155">Weld porosity on assembly A-12</text>
              <rect x="520" y="352" width="56" height="20" rx="10" fill="#F3E8FF"/>
              <text x="531" y="366" font-family="system-ui" font-size="9" font-weight="600" fill="#7C3AED">Closed</text>
              <rect x="620" y="352" width="38" height="20" rx="10" fill="#DBEAFE"/>
              <text x="628" y="366" font-family="system-ui" font-size="9" font-weight="600" fill="#2563EB">Low</text>
              <text x="690" y="364" font-family="system-ui" font-size="11" fill="#64748B">A. Kim</text>

              <!-- Row 5 -->
              <line x1="224" y1="380" x2="752" y2="380" stroke="#F1F5F9" stroke-width="1"/>
